{
  "entities": {
    "Config": {
      "title": "Application Configuration",
      "description": "Global settings for the web app",
      "type": "object",
      "properties": {
        "brandName": { "type": "string" },
        "heroTitle1": { "type": "string" },
        "heroTitle2": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "deliveryFee": { "type": "number" }
      },
      "required": ["brandName", "whatsappNumber"]
    },
    "Category": {
      "title": "Menu Category",
      "description": "Category for products",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "textColor": { "type": "string" },
        "orderId": { "type": "number" }
      },
      "required": ["name"]
    },
    "Collection": {
      "title": "Lookbook Collection",
      "description": "An editorial capsule collection",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "order": { "type": "number" },
        "isFeatured": { "type": "boolean" }
      },
      "required": ["name"]
    },
    "Product": {
      "title": "Product Item",
      "description": "A food item or luxury product in the menu",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "image": { "type": "string" },
        "badge": { "type": "string" },
        "categoryId": { "type": "string" },
        "collectionId": { "type": "string" },
        "material": { "type": "string" },
        "styleNotes": { "type": "string" },
        "sizeGuide": { "type": "string" },
        "popular": { "type": "boolean" }
      },
      "required": ["name", "price", "image"]
    },
    "Order": {
      "title": "Customer Order",
      "description": "An order placed by a customer",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "total": { "type": "number" },
        "items": {
          "type": "array",
          "items": { "type": "object" }
        },
        "status": {
          "type": "string",
          "enum": ["pending", "preparing", "ready", "delivering", "completed", "canceled"]
        },
        "orderMode": { "type": "string" },
        "posId": { "type": "string" },
        "posName": { "type": "string" },
        "driverLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "createdAt": { "type": "string" }
      },
      "required": ["customerName", "total", "status"]
    },
    "PointOfSale": {
      "title": "Store Location",
      "description": "A physical point of sale for the restaurant",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "phone": { "type": "string" },
        "hours": { "type": "object" },
        "priority": { "type": "number" },
        "isOpen": { "type": "boolean" },
        "district": { "type": "string" }
      },
      "required": ["name", "address", "lat", "lng"]
    },
    "Review": {
      "title": "Customer Review",
      "description": "Feedback from customers",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "isApproved": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["customerName", "rating"]
    },
    "ActivityLog": {
      "title": "System Activity",
      "description": "Log of admin actions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "timestamp": { "type": "string" },
        "details": { "type": "string" }
      },
      "required": ["userId", "action", "timestamp"]
    },
    "Promo": {
      "title": "Promotion",
      "description": "Marketing promotions",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percent", "fixed"] },
        "discountValue": { "type": "number" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "isActive": { "type": "boolean" },
        "bannerImage": { "type": "string" }
      },
      "required": ["title", "isActive"]
    },
    "PageContent": {
      "title": "Page Content",
      "description": "CMS for static page content",
      "type": "object",
      "properties": {
        "pageKey": { "type": "string" },
        "sections": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["pageKey"]
    },
    "Admin": {
      "title": "Admin Role",
      "description": "Admin access list",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["email", "role"]
    },
    "User": {
      "title": "Registered User",
      "description": "System user with silhouette profiling and address list",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string" },
        "stature": { "type": "number" },
        "chest": { "type": "number" },
        "waist": { "type": "number" },
        "hips": { "type": "number" },
        "addresses": { "type": "array", "items": { "type": "object" } },
        "paymentMethods": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["email", "role"]
    },
    "Callback": {
      "title": "Callback Request",
      "description": "Request from a customer to be called back by support",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "timeSlot": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["phone"]
    },
    "Driver": {
      "title": "Delivery Driver",
      "description": "A courier or driver associated with a POS",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "posId": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["name", "phone"]
    },
    "Reservation": {
      "title": "Boutique Reservation",
      "description": "Reservation of a personal shopper slot in a physical store",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "guests": { "type": "number" },
        "posId": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["customerName", "phone", "date", "time"]
    }
  },
  "firestore": {
    "/config/{configId}": {
      "schema": { "$ref": "#/entities/Config" },
      "description": "Store config, normally configId is just 'main'"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Product categories"
    },
    "/collections/{collectionId}": {
      "schema": { "$ref": "#/entities/Collection" },
      "description": "Seasonal lookbooks and capsule collections"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Menu products"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders"
    },
    "/points_of_sale/{posId}": {
      "schema": { "$ref": "#/entities/PointOfSale" },
      "description": "Store locations"
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Customer reviews"
    },
    "/activity_logs/{logId}": {
      "schema": { "$ref": "#/entities/ActivityLog" },
      "description": "Admin activity logs"
    },
    "/admins/{userId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "RBAC verification for admins"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Client profile & custom role"
    },
    "/promos/{promoId}": {
      "schema": { "$ref": "#/entities/Promo" },
      "description": "Promotions"
    },
    "/page_content/{pageKey}": {
      "schema": { "$ref": "#/entities/PageContent" },
      "description": "CMS Page content"
    },
    "/callbacks/{callbackId}": {
      "schema": { "$ref": "#/entities/Callback" },
      "description": "Client support callback requests"
    },
    "/drivers/{driverId}": {
      "schema": { "$ref": "#/entities/Driver" },
      "description": "Assigned store couriers"
    },
    "/reservations/{reservationId}": {
      "schema": { "$ref": "#/entities/Reservation" },
      "description": "Personal shopper scheduling"
    }
  }
}
